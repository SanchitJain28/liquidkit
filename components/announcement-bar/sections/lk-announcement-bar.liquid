{{ 'lk-announcement-bar.css' | asset_url | stylesheet_tag }}

<lk-announcement-bar
  data-autoplay="{{ section.settings.autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  data-show-nav="{{ section.settings.show_nav_arrows }}"
>
  <div class="lk-announcement-bar__track" aria-live="polite" aria-label="{{ 'liquid_components.announcement_bar.label' | t }}">
    {%- for block in section.blocks -%}
      {%- if block.settings.message == blank -%}
        {%- continue -%}
      {%- endif -%}

      <div
        class="lk-announcement-bar__slide"
        data-block-id="{{ section.id }}-{{ block.id }}"
        style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="lk-announcement-bar__message">
            {{ block.settings.message }}
          </a>
        {%- else -%}
          <div class="lk-announcement-bar__message">{{ block.settings.message }}</div>
        {%- endif -%}

        {%- if block.settings.dismissible -%}
          <button
            class="lk-announcement-bar__dismiss"
            aria-label="{{ 'liquid_components.announcement_bar.dismiss' | t }}"
            data-dismiss
          >&#x2715;</button>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 and section.settings.show_nav_arrows -%}
    <button class="lk-announcement-bar__nav lk-announcement-bar__nav--prev" aria-label="{{ 'liquid_components.announcement_bar.prev' | t }}">&#8249;</button>
    <button class="lk-announcement-bar__nav lk-announcement-bar__nav--next" aria-label="{{ 'liquid_components.announcement_bar.next' | t }}">&#8250;</button>
  {%- endif -%}
</lk-announcement-bar>

<script src="{{ 'lk-announcement-bar.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "LK Announcement Bar",
  "tag": "div",
  "class": "lk-section-announcement-bar",
  "max_blocks": 10,
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:liquid_components.announcement_bar.settings.autoplay.label",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "t:liquid_components.announcement_bar.settings.autoplay_speed.label",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_nav_arrows",
      "label": "t:liquid_components.announcement_bar.settings.show_nav_arrows.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:liquid_components.announcement_bar.blocks.announcement.name",
      "settings": [
        {
          "type": "richtext",
          "id": "message",
          "label": "t:liquid_components.announcement_bar.blocks.announcement.settings.message.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:liquid_components.announcement_bar.blocks.announcement.settings.link.label"
        },
        {
          "type": "checkbox",
          "id": "dismissible",
          "label": "t:liquid_components.announcement_bar.blocks.announcement.settings.dismissible.label",
          "default": false
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "t:liquid_components.announcement_bar.blocks.announcement.settings.bg_color.label",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "t:liquid_components.announcement_bar.blocks.announcement.settings.text_color.label",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:liquid_components.announcement_bar.name",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
